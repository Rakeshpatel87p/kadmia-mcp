{
  "name": "kadmia-mcp",
  "version": "1.0.1",
  "description": "MCP server for Kadmia API integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kadmia-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f))\" && chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kadmia",
    "ai",
    "claude",
    "openai",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rakeshpatel87p/kadmia-mcp.git"
  },
  "homepage": "https://github.com/rakeshpatel87p/kadmia-mcp#readme",
  "bugs": {
    "url": "https://github.com/rakeshpatel87p/kadmia-mcp/issues"
  },
  "license": "MIT",
  "author": "Kadmia",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
